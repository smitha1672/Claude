#
# This file is part of the Beacon V2 firmware project.
# It defines configuration options for shared power management device modules.
#

menu "Shared PM Device Modules"

config SHARED_PM_DEVICE_MODULES
	bool "Enable Shared PM Device Module"
	default y if PM_DEVICE
	help
	  Enable power management routines for shared peripherals such as I2C and Console.

if SHARED_PM_DEVICE_MODULES

config SHARED_PM_I2C_ENABLE
	bool "Enable I2C Power Management"
	default y
	help
	  Enable suspend/resume handling for I2C device.

config SHARED_PM_CONSOLE_ENABLE
	bool "Enable Console Power Management"
	default y
	help
	  Enable suspend/resume handling for Console.

endif # SHARED_PM_DEVICE_MODULE

endmenu

# I2C device power management

menuconfig PM_DEVICE_I2C
    bool "I2C power management driver"
    depends on I2C && PM_DEVICE
    default y if PM_DEVICE
    help
      Enable infrastructure for I2C bus power management.
      This feature allows control of I2C bus power states
      to optimize power consumption during system operation.

if PM_DEVICE_I2C

config PM_DEVICE_I2C_AUTO_SUSPEND
    bool "Enable automatic I2C power suspension"
    default y
    help
      When enabled, the I2C bus will automatically enter
      suspend state when no devices are actively using it.

config PM_DEVICE_I2C_AUTO_SUSPEND_TIMEOUT_MS
    int "Timeout before automatic suspension (ms)"
    depends on PM_DEVICE_I2C_AUTO_SUSPEND
    default 100
    help
      Time in milliseconds after the last I2C transaction
      before the bus is automatically suspended.

config PM_DEVICE_I2C_INIT_PRIORITY
    int "I2C power management driver initialization priority"
    default 60
    help
      Initialization priority for the I2C power management driver.
      Must be higher than I2C driver init priority.

config PM_DEVICE_I2C_LOG_LEVEL
    int "I2C power management driver log level"
    depends on LOG
    default 1
    range 0 4
    help
      Log level for I2C power management infrastructure.
      0: OFF, 1: ERROR, 2: WARNING, 3: INFO, 4: DEBUG

endif # PM_DEVICE_I2C
